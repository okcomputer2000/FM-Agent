# fm-agent secrets — gitignored, do not commit.
#
# Only secrets belong here. Every non-secret setting now has a committed default
# in fm-agent.toml. To override one without editing that file, set its
# environment variable here (e.g. LLM_MODEL=... or LLM_API_BASE_URL=...) and it
# takes precedence over the toml. See config.py for the full env -> setting map.

# LLM API key. See docs/config_llm.md for provider and prompt-cache setup.
LLM_API_KEY=YOUR_LLM_API_KEY
